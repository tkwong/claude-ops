# claude-ops environment.
# Copy to .env and source it from your shell rc, or pass per-command.

# Where claude-ops stores agent configs and per-agent state.
# Default: ~/.claude-ops
# CLAUDE_OPS_HOME=$HOME/.claude-ops

# Where the watchdog logs to.
# WATCHDOG_LOG=/tmp/claude-ops-watchdog.log

# AWS / S3 backup (optional, see lib/backup-to-s3.sh)
# Either rely on EC2 IAM instance role, or set:
# AWS_PROFILE=default
# AWS_REGION=us-east-1
